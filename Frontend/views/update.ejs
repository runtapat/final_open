<h1>📝 แก้ไขหนังสือ</h1>
<form method="POST" action="/edit/<%= book.id %>">
    <label>ชื่อหนังสือ:</label> <input type="text" name="title" value="<%= book.title %>" required><br><br>
    <label>ราคา:</label> <input type="number" name="price" value="<%= book.price %>" required><br><br>

    <label>ผู้แต่ง:</label>
    <select name="authorId" required>
        <% authors.forEach(a => { %><option value="<%= a.id %>" <%= book.authorId === a.id ? 'selected' : '' %>><%= a.name %></option><% }) %>
    </select><br><br>

    <label>หมวดหมู่:</label>
    <select name="genreId" required>
        <% genres.forEach(g => { %><option value="<%= g.id %>" <%= book.genreId === g.id ? 'selected' : '' %>><%= g.name %></option><% }) %>
    </select><br><br>

    <button type="submit">อัปเดต</button>
</form>